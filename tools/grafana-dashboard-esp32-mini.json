          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "esp32_consecutive_skips_wet{job=\"esp32_watering_mini\"}",
          "legendFormat": "skips",
