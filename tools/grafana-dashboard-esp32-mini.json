          "unit": "dateTimeAsIso"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "esp32_schedule_last_run_unix{job=\"esp32_watering_mini\"} * 1000",
          "legendFormat": "last_run",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Schedule Next Run",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
