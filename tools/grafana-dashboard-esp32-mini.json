{
  "id": null,
  "uid": "esp32-watering-mini",
  "title": "ESP32 Watering System (mini)",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
