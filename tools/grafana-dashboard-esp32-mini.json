    {
      "id": 200,
      "type": "row",
      "title": "Soil & Overflow Sensors",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Soil Raw vs Threshold",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "description": "Lower raw = wetter soil. Threshold line is the wet/dry boundary - when raw drops below threshold the schedule treats the soil as wet and skips.",
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short",
          "min": 0,
          "max": 4095
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "esp32_soil_raw{job=\"esp32_watering_mini\"}",
          "legendFormat": "raw",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "esp32_soil_threshold{job=\"esp32_watering_mini\"}",
          "legendFormat": "threshold",
          "refId": "B"
        }
      ]
    },
