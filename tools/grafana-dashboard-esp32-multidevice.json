{
  "id": null,
  "uid": "esp32-watering-multidevice",
  "title": "ESP32 Watering (multi-device)",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "Europe/Moscow",
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "tags": [
    "esp32",
    "watering",
    "iot",
    "mini",
    "multi-device"
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "name": "Watering starts",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(0, 200, 100, 1)",
        "expr": "changes(esp32_motor_on{job=\"esp32_watering\",device=~\"$device\"}[1m]) > 0 and esp32_motor_on{job=\"esp32_watering\",device=~\"$device\"} == 1",
        "step": "1m",
        "titleFormat": "watering started ({{device}})",
        "textFormat": "motor_on 0 \u2192 1",
        "tagKeys": "device"
      },
      {
        "name": "Overflow trips",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(220, 0, 0, 1)",
        "expr": "changes(esp32_overflow_latched{job=\"esp32_watering\",device=~\"$device\"}[1m]) > 0 and esp32_overflow_latched{job=\"esp32_watering\",device=~\"$device\"} == 1",
        "step": "1m",
        "titleFormat": "overflow latched ({{device}})",
        "textFormat": "L1 safety \u2014 motor forced off",
        "tagKeys": "device"
      },
      {
        "name": "Reboots",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255, 165, 0, 1)",
        "expr": "resets(esp32_uptime_ms{job=\"esp32_watering\",device=~\"$device\"}[5m]) > 0",
        "step": "1m",
        "titleFormat": "reboot ({{device}})",
        "textFormat": "uptime counter reset",
        "tagKeys": "device"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "device",
        "label": "Device",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(last_over_time(esp32_motor_on{job=\"esp32_watering\"}[15m]), device)",
          "refId": "StandardVariableQuery"
        },
        "definition": "label_values(last_over_time(esp32_motor_on{job=\"esp32_watering\"}[15m]), device)",
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "regex": "",
        "hide": 0
      },
      {
        "name": "instance",
        "label": "Instance (fallback)",
        "description": "Use if device labels collide. Backed by Prometheus scrape target.",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(last_over_time(esp32_motor_on{job=\"esp32_watering\"}[15m]), instance)",
          "refId": "StandardVariableQuery"
        },
        "definition": "label_values(last_over_time(esp32_motor_on{job=\"esp32_watering\"}[15m]), instance)",
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "regex": "",
        "hide": 0
      }
    ]
  },
